rules_version = '2';

// Database.md §Security Rules 요지를 그대로 구현(architect 소유 문서, implementer는 그대로 구현).
// 핵심 원칙: 본인(uid) 귀속만 read/write. scenarioPrompts는 클라 전면 거부(ADR-0004).
// 대화 로그(messages)·합성물 메타(artifacts)는 서버(Functions, PII 마스킹·가드레일 강제) 전용
// write — 클라 직접 write를 열면 ADR-0004의 마스킹 보장을 우회할 수 있어 원천 차단한다.
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — 본인 귀속(DECISIONS #13)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // users/{uid}/consents/{consentId} — 동의 로그(UX-001, AC-012/017)
      match /consents/{consentId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // users/{uid}/voices/{voiceId} — 유지형 복제 음성 보관함(T30, ADR-0005, Database.md 1:1).
      // UX-025 "기존 목소리 재사용" 조회 대상. write는 아직 이 컬렉션을 채우는 콜러블/UI가 없어
      // (P-8, 범위 밖) false로 막는다 — 채우는 기능이 생기면 그때 Functions 전용 write로 연다.
      match /voices/{voiceId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // sessions/{sessionId} — 소유 uid만 read. write는 전부 Functions(admin SDK, 규칙 우회)만.
    // #3 보안 하드닝(2026-07-22): 예전엔 소유자면 create/update/delete를 허용했으나, 클라가
    // sessions 문서를 직접 쓰는 경로가 실제로는 없고(세션 생성·수정은 전부 콜러블 경유), 열려
    // 있으면 클라가 maxUserTurns(한도 우회)·voiceId(실 ElevenLabs 전환 시 타인 voice 주입·도용)·
    // status 등을 임의 조작해 서버 불변식을 우회할 수 있었다. 클라 write를 원천 차단한다.
    match /sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;

      // messages/artifacts는 서버(Functions admin SDK)만 write — PII 마스킹(ADR-0004)/
      // 폐기 매니페스트(ADR-0003) 보장을 클라가 우회할 수 없도록 원천 차단.
      match /messages/{messageId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.uid == request.auth.uid;
        allow write: if false;
      }

      match /artifacts/{artifactId} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.uid == request.auth.uid;
        allow write: if false;
      }
    }

    // scenarios/{} — 인증 사용자 read 허용(공개 메타). write 금지(seed/admin, Database.md §Migration Policy)
    match /scenarios/{scenarioId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // scenarioPrompts/{} — 클라 read/write 전면 거부(Functions/admin only, ADR-0004)
    match /scenarioPrompts/{scenarioId} {
      allow read, write: if false;
    }

    // reports/{} — 소유 uid만 read. write는 Functions(admin)만(generateReport, T9).
    match /reports/{reportId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // deletionLogs/{} — 감사 로그. 소유 uid만 read. write는 Functions(admin)만(onSessionEnded, T10).
    match /deletionLogs/{logId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // challenges/{} — 2인 소셜 챌린지(T36, Database.md §Security Rules 요지 그대로 구현, AC-041/043).
    // 사용자1(creatorUid) 본인만 read(UX-020 대시보드). 사용자2는 무로그인이라 직접 read 불가 —
    // 전부 Functions(토큰 매개, T37 소관)로만 접근한다. write는 클라 직접 전면 금지 — 생성·토큰
    // 검증·개수 상한·삭제 모두 Functions(admin)만 강제한다(AC-041/044/048/049).
    match /challenges/{challengeId} {
      allow read: if request.auth != null && resource.data.creatorUid == request.auth.uid;
      allow write: if false;
    }

    // 그 외 모든 경로는 기본 거부.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# Copy this file to functions/.env for local emulation. Never commit functions/.env.
# 프로덕션 배포 시에는 이 값들을 `firebase functions:secrets:set <NAME>` 또는
# `firebase functions:config:set`(2nd gen은 secrets 권장)으로 설정한다 — 파일로 배포 서버에
# 올리지 않는다. 이 값들은 Cloud Functions 런타임에서만 사용되며 클라이언트 번들에는
# 절대 포함되지 않는다(Architecture.md §8, API.md Conventions).

# ElevenLabs Instant Voice Cloning + TTS API 키 (T1 PoC 착수 전 사용자가 크레딧/rate limit
# 확인 필요 — PRD OQ-14). 키 미준비 시 T19 목업(Mock TTS)으로 개발 진행.
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY

# LLM(사기범 역할극·리포트 생성) API 키. 프로바이더는 LLM_PROVIDER로 선택(Claude|Gemini 어댑터, DECISIONS #11).
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_PROVIDER=claude

# 클론/합성 타임아웃 초과 시 폴백용 사전 준비 voiceId(OQ-U3, DECISIONS #9).
FALLBACK_VOICE_ID=YOUR_FALLBACK_VOICE_ID

# Copy this file to functions/.env for local emulation. Never commit functions/.env.
# 프로덕션 배포 시에는 이 값들을 `firebase functions:secrets:set <NAME>` 또는
# `firebase functions:config:set`(2nd gen은 secrets 권장)으로 설정한다 — 파일로 배포 서버에
# 올리지 않는다. 이 값들은 Cloud Functions 런타임에서만 사용되며 클라이언트 번들에는
# 절대 포함되지 않는다(Architecture.md §8, API.md Conventions).

# ElevenLabs Instant Voice Cloning + TTS + Agents(실시간 음성 통화) API 키.
# 키 미준비 시 목업(Mock TTS / 텍스트 폴백 대화)으로 개발 진행한다.
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY

# 실시간 음성 통화(speech-to-speech)용 시나리오별 ElevenLabs 에이전트 매핑.
# 형식: `scenarioId:agentId` 를 쉼표로 구분.
#   예) ELEVENLABS_AGENT_IDS=family-accident-deepvoice:agent_xxx,tax-refund-scam:agent_yyy
#
# 왜 에이전트에 프롬프트를 두는가(ADR-0004): ElevenLabs 오버라이드는 **클라이언트가 보내는 값**이라,
# 페르소나 프롬프트를 오버라이드로 넘기면 브라우저에 민감 프롬프트가 노출된다. 그래서 시나리오별
# 에이전트를 미리 만들어 프롬프트를 그쪽에 저장하고, 서버는 서명 URL만 발급한다. 클라가 보내는
# 오버라이드는 민감하지 않은 voice_id/language뿐이다.
#
# 각 에이전트에 넣을 프롬프트 원문은 이 저장소에 이미 있다 — functions/src/scenarios/*.prompt.ts 를
# roleplay/promptAssembly.buildSystemPrompt()로 조립한 문자열을 그대로 붙여넣는다(직접 손으로 다시
# 쓰지 말 것 — 드리프트 방지). 에이전트 설정에서 language=ko, 저지연 모델(Flash 계열)을 선택한다.
# 미설정이면 실시간 통화 대신 텍스트 폴백으로 자동 강등된다(응답의 isMock:true로 클라에 알림).
ELEVENLABS_AGENT_IDS=

# LLM(사기범 역할극·리포트 생성) API 키. 프로바이더는 LLM_PROVIDER로 선택(Claude|Gemini 어댑터, DECISIONS #11).
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_PROVIDER=claude

# 클론/합성 타임아웃 초과 시 폴백용 사전 준비 voiceId(OQ-U3, DECISIONS #9).
FALLBACK_VOICE_ID=YOUR_FALLBACK_VOICE_ID
